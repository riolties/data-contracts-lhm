{
  "domain": "mobilitaetsreferat",
  "product": "radverkehr",
  "title": "Radverkehr Tageswerte München",
  "description": {
    "purpose": "Tägliche Radverkehrszahlen je Dauerzählstelle inkl. Wetter.",
    "usage": "Mobilitätsplanung, Monitoring, Open-Data-Veröffentlichung.",
    "limitations": "Nur Dauerzählstellen; Wetter aggregiert je Tag."
  },
  "owner": {
    "data_owner": "dateneigner.mobilitaet@muenchen.de",
    "data_steward": "steward.mobilitaet@muenchen.de",
    "contact": "open.data@muenchen.de"
  },
  "classification": "public",
  "update_frequency": "P1D",
  "personal_data": false,
  "open_data_candidate": true,
  "license": "https://www.govdata.de/dl-de/by-2-0",
  "spatial": "https://sws.geonames.org/2867714/",
  "govdata_category": ["http://publications.europa.eu/resource/authority/data-theme/TRAN"],
  "source": {
    "type": "file_export",
    "location": "data/sample_radverkehr_tageswerte_2025_01.csv"
  },
  "columns": [
    {"name": "datum", "logical_type": "date", "description": "Zähltag (Quellformat YYYY.MM.DD).", "classification": "public"},
    {"name": "uhrzeit_start", "logical_type": "time", "description": "Beginn des Zählintervalls (in der Quelle konstant 00:00 = Tagesbeginn).", "internal": true},
    {"name": "uhrzeit_ende", "logical_type": "string", "description": "Ende des Zählintervalls; Quelle nutzt '.' als Trenner (23.59) — im Staging zu normalisieren.", "internal": true},
    {"name": "zaehlstelle", "logical_type": "string", "description": "Name der Dauerzählstelle (z.B. Arnulf, Erhardt).", "classification": "public"},
    {"name": "richtung_1", "logical_type": "integer", "description": "Gezählte Radfahrten in Richtung 1."},
    {"name": "richtung_2", "logical_type": "integer", "description": "Gezählte Radfahrten in Richtung 2."},
    {"name": "gesamt", "logical_type": "integer", "description": "Gesamtzahl Radfahrten am Tag (= richtung_1 + richtung_2)."},
    {"name": "min-temp", "logical_type": "number", "description": "Tagestiefsttemperatur in °C (Begleitwetter)."},
    {"name": "max-temp", "logical_type": "number", "description": "Tageshöchsttemperatur in °C (Begleitwetter)."},
    {"name": "niederschlag", "logical_type": "number", "description": "Niederschlagsmenge in mm (Begleitwetter)."},
    {"name": "bewoelkung", "logical_type": "integer", "description": "Bewölkungsgrad in Prozent (0–100, Begleitwetter)."},
    {"name": "sonnenstunden", "logical_type": "number", "description": "Sonnenscheindauer in Stunden (Begleitwetter)."}
  ],
  "quality_rules": [
    {"rule": "range", "column": "bewoelkung", "min": 0, "max": 100},
    {"rule": "unique", "columns": ["datum", "zaehlstelle"]}
  ]
}
