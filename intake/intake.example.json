{
  "domain": "mobilitaetsreferat",
  "product": "radverkehr",
  "title": "Radverkehr Tageswerte München",
  "description": {
    "purpose": "Tägliche Radverkehrszahlen je Dauerzählstelle inkl. Wetter.",
    "usage": "Mobilitätsplanung, Monitoring, Open-Data-Veröffentlichung.",
    "limitations": "Nur Dauerzählstellen; Wetter aggregiert je Tag."
  },
  "owner": {
    "data_owner": "dateneigner.mobilitaet@muenchen.de",
    "data_steward": "steward.mobilitaet@muenchen.de",
    "contact": "open.data@muenchen.de"
  },
  "classification": "public",
  "update_frequency": "P1D",
  "personal_data": false,
  "open_data_candidate": true,
  "license": "https://www.govdata.de/dl-de/by-2-0",
  "spatial": "https://sws.geonames.org/2867714/",
  "govdata_category": ["http://publications.europa.eu/resource/authority/data-theme/TRAN"],
  "source": {
    "type": "file_export",
    "location": "data/sample_radverkehr_tageswerte_2025_01.csv"
  },
  "columns": [
    {"name": "datum", "logical_type": "date", "physical_type": "string", "required": true, "description": "Zähltag.", "classification": "public"},
    {"name": "uhrzeit_start", "logical_type": "string", "physical_type": "string", "description": "Beginn Aggregationsfenster."},
    {"name": "uhrzeit_ende", "logical_type": "string", "physical_type": "string", "description": "Ende Aggregationsfenster."},
    {"name": "zaehlstelle", "logical_type": "string", "physical_type": "string", "required": true, "description": "Name der Zählstelle."},
    {"name": "richtung_1", "logical_type": "integer", "physical_type": "string", "description": "Räder Richtung 1."},
    {"name": "richtung_2", "logical_type": "integer", "physical_type": "string", "description": "Räder Richtung 2."},
    {"name": "gesamt", "logical_type": "integer", "physical_type": "string", "required": true, "description": "Summe beider Richtungen."},
    {"name": "min-temp", "logical_type": "number", "physical_type": "string", "description": "Minimaltemperatur °C."},
    {"name": "max-temp", "logical_type": "number", "physical_type": "string", "description": "Maximaltemperatur °C."},
    {"name": "niederschlag", "logical_type": "number", "physical_type": "string", "description": "Niederschlag mm."},
    {"name": "bewoelkung", "logical_type": "integer", "physical_type": "string", "description": "Bewölkung %."},
    {"name": "sonnenstunden", "logical_type": "number", "physical_type": "string", "description": "Sonnenstunden."}
  ],
  "quality_rules": [
    {"rule": "not_null", "column": "datum"},
    {"rule": "not_null", "column": "gesamt"},
    {"rule": "range", "column": "bewoelkung", "min": 0, "max": 100},
    {"rule": "range", "column": "gesamt", "min": 0, "max": 1000000},
    {"rule": "expression", "expr": "gesamt = richtung_1 + richtung_2"}
  ]
}
